# Defaults for the Postgres BDD suite.
#
# The test loader reads this file without overriding values already exported in
# the shell. Set RUN_POSTGRES_BEHAVIOUR=1 when a real Postgres + pgvector
# database is available.

RUN_POSTGRES_BEHAVIOUR=0

POSTGRES_DB=convfinqa_bdd
POSTGRES_USER=convfinqa
POSTGRES_PASSWORD=convfinqa
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONNECTION_URL=postgresql+psycopg://convfinqa:convfinqa@localhost:5432/convfinqa_bdd
POSTGRES_BEHAVIOUR_URL=postgresql+psycopg://convfinqa:convfinqa@localhost:5432/convfinqa_bdd

MODEL_CONFIG_PATH=configs/model_config.bdd.toml
RAW_DATA_PATH=data/samples/convfinqa_dev_sample.json
BDD_SAMPLE_DATA_PATH=data/samples/convfinqa_dev_sample.json
CACHING_ON=False
